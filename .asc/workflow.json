{
  // Release automation. Run: asc workflow run ship-ios VERSION:x.y.z
  "env": { "IOS_APP_ID": "6785764864", "MAC_APP_ID": "", "VERSION": "", "SUBMIT": "true" },
  "before_all": "asc auth status",
  "workflows": {
    "ship-ios": { "description": "Bump, archive, upload, submit iOS", "steps": [
      { "name": "bump", "run": "cd ios && asc xcode version edit --version \"$VERSION\" --build-number \"$(date +%Y%m%d%H%M)\"" },
      { "name": "archive", "run": "cd ios && asc xcode archive --project Healstack.xcodeproj --scheme Dose --archive-path ../.asc/artifacts/Healstack.xcarchive --output json" },
      { "name": "export", "run": "cd ios && asc xcode export --archive-path ../.asc/artifacts/Healstack.xcarchive --export-options ExportOptions.plist --ipa-path ../.asc/artifacts/Healstack.ipa --output json" },
      { "name": "publish", "if": "SUBMIT", "run": "asc publish appstore --app $IOS_APP_ID --ipa .asc/artifacts/Healstack.ipa --version $VERSION --wait --submit --confirm --output json" }
    ] }
  }
}
